#!/bin/bash
# ==================================
#      CHROMEBOOK WP DIAGNOSTIC
#      Version: 33
# ==================================

# ---------- COLORS ----------
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

clear
echo -e "\033[1;36mChromebook WP Diagnostic Script - Version 33 - By CriticalHD/neonnebula\033[0m"
echo -e "${YELLOW}==================================${NC}"
echo -e "${YELLOW}      CHROMEBOOK WP DIAGNOSTIC${NC}"
echo -e "${YELLOW}==================================${NC}"

# ---------- FUNCTIONS ----------

get_hw_wp() {

cs_wp=$(crossystem wpsw_cur 2>/dev/null)
fr_wp=$(flashrom --wp-status 2>/dev/null | grep -i "enabled")

if [[ "$cs_wp" == "1" ]] || [[ -n "$fr_wp" ]]; then
echo "enabled"
else
echo "disabled"
fi
}

get_capability() {

cap="$1"
line=$(echo "$GSC_I" | grep -i "$cap")

state=$(echo "$line" | grep -oE 'Never|IfOpened|Always|0|1|2' | head -n1)

case "$state" in
Never|0) color=$RED label="Never" ;;
IfOpened|1) color=$BLUE label="IfOpened" ;;
Always|2) color=$GREEN label="Always" ;;
*) color=$YELLOW label="Unknown" ;;
esac

printf "%-20s %b\n" "$cap:" "${color}${label}${NC}"
}

print_diagnostics() {

echo
echo -e "${GREEN}----- CROSSYSTEM -----${NC}"

wpsw=$(crossystem wpsw_cur 2>/dev/null)
devsw=$(crossystem devsw_cur 2>/dev/null)
devusb=$(crossystem dev_boot_usb 2>/dev/null)

echo -e "Hardware WP switch: ${YELLOW}$wpsw${NC}"
echo -e "Developer Mode: ${YELLOW}$devsw${NC}"
echo -e "USB Boot: ${YELLOW}$devusb${NC}"

echo
echo -e "${GREEN}----- GSC STATUS -----${NC}"

flash_wp=$(gsctool -a -w 2>/dev/null | grep -i "Flash WP" | awk '{print $3}')

if [[ "$flash_wp" == "enabled" ]]; then
echo -e "GSC Flash WP: ${RED}ENABLED${NC}"
else
echo -e "GSC Flash WP: ${GREEN}DISABLED${NC}"
fi

echo
echo -e "${GREEN}----- CCD STATE -----${NC}"

GSC_I=$(gsctool -a -I 2>/dev/null)

ccd_state=$(echo "$GSC_I" | grep -i "^State" | awk '{print $2}')

case "$ccd_state" in
Locked) echo -e "CCD: ${RED}LOCKED${NC}" ;;
Opened|Open) echo -e "CCD: ${GREEN}OPENED${NC}" ;;
Debug) echo -e "CCD: ${BLUE}DEBUG${NC}" ;;
*) echo -e "CCD: ${YELLOW}UNKNOWN${NC}" ;;
esac

echo
echo -e "${GREEN}----- IMPORTANT CAPABILITIES -----${NC}"

get_capability AllowUnverifiedRo
get_capability OverrideWP
get_capability FlashAP
get_capability FlashRead
get_capability GscFullConsole

echo
echo -e "${GREEN}----- SPI FLASH ACCESS TEST -----${NC}"

TMP=$(mktemp)

flashrom -p internal -r "$TMP" >/dev/null 2>&1

if [[ $? == 0 ]]; then
echo -e "${GREEN}SPI read SUCCESS${NC}"
else
echo -e "${RED}SPI read FAILED${NC}"
fi

rm -f "$TMP"

}

security_scan() {

echo -e "${CYAN}Running Chromebook Security Scan...${NC}"
echo

echo -e "${GREEN}Board Information${NC}"

board=$(crossystem hwid 2>/dev/null)
echo "HWID: $board"

platform=$(crossystem platform 2>/dev/null)
echo "Platform: $platform"

echo
echo -e "${GREEN}Security Chip${NC}"

chip=$(gsctool -a -I 2>/dev/null | grep -i "running" | head -n1)

if echo "$chip" | grep -qi ti50; then
echo -e "Chip: ${GREEN}Ti50${NC}"
elif echo "$chip" | grep -qi cr50; then
echo -e "Chip: ${GREEN}Cr50${NC}"
else
echo -e "Chip: ${YELLOW}Unknown${NC}"
fi

echo
echo -e "${GREEN}Debug Interfaces${NC}"

if ls /dev/ttyUSB* >/dev/null 2>&1; then
echo -e "CCD / SuzyQ: ${GREEN}Detected${NC}"
else
echo -e "CCD / SuzyQ: ${YELLOW}Not detected${NC}"
fi

if lsusb 2>/dev/null | grep -qi servo; then
echo -e "Servo Debug: ${GREEN}Detected${NC}"
else
echo -e "Servo Debug: ${YELLOW}Not detected${NC}"
fi

echo
echo -e "${GREEN}Firmware State${NC}"

fwslot=$(crossystem mainfw_act 2>/dev/null)

echo "Active Firmware Slot: $fwslot"

devmode=$(crossystem devsw_cur 2>/dev/null)

if [[ "$devmode" == "1" ]]; then
echo -e "Developer Mode: ${GREEN}ENABLED${NC}"
else
echo -e "Developer Mode: ${RED}DISABLED${NC}"
fi

}

# ---------- INITIAL DIAGNOSTICS ----------

print_diagnostics

# CCD indicator

if [[ "$ccd_state" == "Locked" ]]; then
CCD_WARN="${RED}[CCD LOCKED]${NC}"
else
CCD_WARN="${GREEN}[CCD OPEN]${NC}"
fi

# ---------- MENU ----------

while true; do

echo
echo -e "${CYAN}===== PAYLOAD MENU =====${NC}"
echo
echo -e "${GREEN}[1]${NC} Generate & Upload VT2 Diagnostic Log"
echo -e "${GREEN}[2]${NC} Set Important CCD Capabilities to Always ${CCD_WARN}"
echo -e "${GREEN}[3]${NC} Firmware Flash Safety Check"
echo -e "${GREEN}[4]${NC} Chromebook Security Scan"
echo -e "${YELLOW}[e]${NC} Exit"
echo

read -n1 -rp "Choice: " choice
echo

case "$choice" in

1)

TMPFILE=$(mktemp)

{
echo "==== VT2 DIAGNOSTIC LOG ===="
date
echo
crossystem
echo
gsctool -a -I
echo
dmesg
} > "$TMPFILE"

echo -e "${CYAN}Uploading log...${NC}"

URL=$(curl -s --upload-file "$TMPFILE" https://transfer.sh/vt2_log.log)

if [[ "$URL" == http* ]]; then
echo -e "${GREEN}Upload successful${NC}"
echo "$URL"
else
echo -e "${RED}Upload failed${NC}"
fi

rm -f "$TMPFILE"

;;

2)

echo -e "${CYAN}Setting CCD capabilities...${NC}"

gsctool -a -I FlashAP:always
gsctool -a -I OverrideWP:always
gsctool -a -I GscFullConsole:always
gsctool -a -I AllowUnverifiedRo:always

echo -e "${GREEN}Done.${NC}"

;;

3)

echo -e "${CYAN}Running Firmware Flash Safety Check${NC}"
echo

hw_wp=$(get_hw_wp)

if [[ "$hw_wp" == "disabled" ]]; then
echo -e "Hardware WP: ${GREEN}DISABLED${NC}"
hw_ok=1
else
echo -e "Hardware WP: ${RED}ENABLED${NC}"
hw_ok=0
fi

gsc_wp=$(gsctool -a -w 2>/dev/null | grep -i "Flash WP" | awk '{print $3}')

if [[ "$gsc_wp" == "disabled" ]]; then
echo -e "GSC Flash WP: ${GREEN}DISABLED${NC}"
gsc_ok=1
else
echo -e "GSC Flash WP: ${RED}ENABLED${NC}"
gsc_ok=0
fi

flashap=$(gsctool -a -I 2>/dev/null | grep -i FlashAP)

if echo "$flashap" | grep -qi Always; then
echo -e "FlashAP Permission: ${GREEN}ALWAYS${NC}"
cap_ok=1
elif echo "$flashap" | grep -qi IfOpened; then
echo -e "FlashAP Permission: ${YELLOW}RESTRICTED (IfOpened)${NC}"
cap_ok=2
else
echo -e "FlashAP Permission: ${RED}DENIED${NC}"
cap_ok=0
fi

TMP=$(mktemp)
flashrom -p internal -r "$TMP" >/dev/null 2>&1

if [[ $? == 0 ]]; then
echo -e "SPI Access: ${GREEN}WORKING${NC}"
spi_ok=1
else
echo -e "SPI Access: ${RED}FAILED${NC}"
spi_ok=0
fi

rm -f "$TMP"

echo
echo -e "${MAGENTA}----- RESULT -----${NC}"

if [[ $hw_ok == 1 && $gsc_ok == 1 && $cap_ok == 1 && $spi_ok == 1 ]]; then
echo -e "${GREEN}SAFE TO FLASH${NC}"
elif [[ $hw_ok == 1 && $gsc_ok == 1 && $cap_ok == 2 && $spi_ok == 1 ]]; then
echo -e "${YELLOW}FLASHING RESTRICTED (CCD must stay open)${NC}"
else
echo -e "${RED}NOT SAFE TO FLASH${NC}"
fi

;;

4)

security_scan

;;

e|E)
echo "Exiting..."
break
;;

*)
echo -e "${RED}Invalid option${NC}"
sleep 1
;;

esac

done
