#!/bin/bash
# ==================================
#      CHROMEBOOK WP DIAGNOSTIC
#      Version: 34
# ==================================

# ---------- COLORS ----------
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

clear
echo -e "\033[1;36mChromebook WP Diagnostic Script - Version 34 - By CriticalHD/neonnebula\033[0m"
echo -e "${YELLOW}==================================${NC}"
echo -e "${YELLOW}      CHROMEBOOK WP DIAGNOSTIC${NC}"
echo -e "${YELLOW}==================================${NC}"

# ---------- FUNCTIONS ----------

get_hw_wp() {
    cs_wp=$(crossystem wpsw_cur 2>/dev/null)
    fr_wp=$(flashrom --wp-status 2>/dev/null | grep -i enabled)

    if [[ "$cs_wp" == "1" ]] || [[ -n "$fr_wp" ]]; then
        echo "enabled"
    else
        echo "disabled"
    fi
}

print_diagnostics() {

echo -e "\n${GREEN}----- CROSSYSTEM (Firmware / DevMode info) -----${NC}"

wpsw=$(crossystem wpsw_cur 2>/dev/null)
devsw=$(crossystem devsw_cur 2>/dev/null)
dev_usb=$(crossystem dev_boot_usb 2>/dev/null)
dev_signed=$(crossystem dev_boot_signed_only 2>/dev/null)

echo -e "wpsw_cur: ${YELLOW}$wpsw${NC}"
echo -e "devsw_cur: ${YELLOW}$devsw${NC}"
echo -e "dev_boot_usb: ${YELLOW}$dev_usb${NC}"
echo -e "dev_boot_signed_only: ${YELLOW}$dev_signed${NC}"

echo -e "\n${GREEN}----- GSC / Ti50 Status -----${NC}"

flash_wp=$(gsctool -a -w 2>/dev/null | grep -i "Flash WP" | awk '{print $3}')

if [[ "$flash_wp" == "enabled" ]]; then
echo -e "Flash WP: ${RED}Enabled${NC}"
else
echo -e "Flash WP: ${GREEN}Disabled${NC}"
fi

echo -e "\n${GREEN}----- CCD Information -----${NC}"

GSC_I=$(gsctool -a -I 2>/dev/null)
GSC_W=$(gsctool -a -W 2>/dev/null)

ccd_mode=$(echo "$GSC_W" | grep -i ccd_mode | tr -dc '0-9')

case "$ccd_mode" in
0) echo -e "CCD Mode: ${RED}Locked${NC}" ;;
1) echo -e "CCD Mode: ${GREEN}Opened${NC}" ;;
2) echo -e "CCD Mode: ${BLUE}Debug${NC}" ;;
*) echo -e "CCD Mode: ${YELLOW}Unknown${NC}" ;;
esac

ccd_state=$(echo "$GSC_I" | grep -i "^State" | awk '{print $2}')

case "$ccd_state" in
Locked) echo -e "CCD State: ${RED}Locked${NC}" ;;
Opened|Open) echo -e "CCD State: ${GREEN}Opened${NC}" ;;
Debug) echo -e "CCD State: ${BLUE}Debug${NC}" ;;
*) echo -e "CCD State: ${YELLOW}Unknown${NC}" ;;
esac

get_cap() {

cap="$1"
line=$(echo "$GSC_I" | grep -i "$cap")
state=$(echo "$line" | grep -oE 'Never|IfOpened|Always' | head -n1)

case "$state" in
Never) out="${RED}Never${NC}" ;;
IfOpened) out="${BLUE}IfOpened${NC}" ;;
Always) out="${GREEN}Always${NC}" ;;
*) out="${YELLOW}Unknown${NC}" ;;
esac

printf "%-20s %b\n" "$cap:" "$out"
}

echo
get_cap AllowUnverifiedRo
get_cap OverrideWP
get_cap FlashAP
get_cap FlashRead
get_cap GscFullConsole

echo -e "\n${GREEN}----- SPI Flash Status -----${NC}"

if command -v flashrom >/dev/null 2>&1; then
flash_status=$(flashrom --wp-status 2>/dev/null | grep -E "enabled|disabled")

if [[ -n "$flash_status" ]]; then
echo -e "${MAGENTA}$flash_status${NC}"
else
echo -e "${RED}SPI flash status unavailable${NC}"
fi
else
echo -e "${RED}flashrom not installed${NC}"
fi

echo -e "\n${GREEN}----- Kernel Messages -----${NC}"

kernel_msgs=$(dmesg | grep -iE "write-protect|wp:" | tail -n 10)

if [[ -n "$kernel_msgs" ]]; then
echo -e "${CYAN}$kernel_msgs${NC}"
else
echo -e "${RED}No relevant kernel WP messages${NC}"
fi

echo -e "\n${GREEN}----- Firmware Read Test (SPI Only) -----${NC}"

TMP=$(mktemp)

flashrom -p internal -r "$TMP" >/dev/null 2>&1

if [[ $? -eq 0 ]]; then
echo -e "${GREEN}Flash read SUCCESS${NC}"
else
echo -e "${RED}Flash read FAILED${NC}"
fi

rm -f "$TMP"

}

security_scan(){

echo -e "${CYAN}Running Chromebook Security Scan...${NC}"
echo

echo -e "${GREEN}Board${NC}"
crossystem hwid 2>/dev/null

echo
echo -e "${GREEN}Security Chip${NC}"
gsctool -a -I 2>/dev/null | grep -i running | head -n1

echo
echo -e "${GREEN}Debug Interfaces${NC}"

ls /dev/ttyUSB* >/dev/null 2>&1 && \
echo -e "CCD / SuzyQ: ${GREEN}Detected${NC}" || \
echo -e "CCD / SuzyQ: ${YELLOW}Not detected${NC}"

lsusb | grep -qi servo && \
echo -e "Servo Debug: ${GREEN}Detected${NC}" || \
echo -e "Servo Debug: ${YELLOW}Not detected${NC}"

}

# ---------- INITIAL DIAGNOSTICS ----------

print_diagnostics

if [[ "$ccd_state" == "Locked" ]]; then
CCD_WARN="${RED}[CCD LOCKED]${NC}"
else
CCD_WARN="${GREEN}[CCD OPEN]${NC}"
fi

echo
echo -e "${CYAN}===== PAYLOAD MENU =====${NC}"

tput sc

while true; do

tput rc
tput ed

echo
echo -e "${GREEN}[1]${NC} Generate & Upload VT2 Diagnostic Log"
echo -e "${GREEN}[2]${NC} Set Important CCD Capabilities to Always ${CCD_WARN}"
echo -e "${GREEN}[3]${NC} Firmware Flash Safety Check"
echo -e "${GREEN}[4]${NC} Chromebook Security Scan"
echo -e "${YELLOW}[e]${NC} Exit"
echo

read -n1 -rp "Choice: " choice </dev/tty
echo

case "$choice" in

2)
echo -e "${CYAN}Setting CCD capabilities...${NC}"
gsctool -a -I FlashAP:always
gsctool -a -I OverrideWP:always
gsctool -a -I GscFullConsole:always
gsctool -a -I AllowUnverifiedRo:always
echo -e "${GREEN}Done.${NC}"
read -n1 -rp "Press any key..." </dev/tty
;;

3)
echo -e "${CYAN}Running Firmware Flash Safety Check${NC}"
hw=$(get_hw_wp)

[[ "$hw" == "disabled" ]] && \
echo -e "Hardware WP: ${GREEN}DISABLED${NC}" || \
echo -e "Hardware WP: ${RED}ENABLED${NC}"

flashap=$(gsctool -a -I | grep -i FlashAP)

if echo "$flashap" | grep -qi Always; then
echo -e "FlashAP: ${GREEN}ALWAYS${NC}"
elif echo "$flashap" | grep -qi IfOpened; then
echo -e "FlashAP: ${YELLOW}RESTRICTED${NC}"
else
echo -e "FlashAP: ${RED}DENIED${NC}"
fi

read -n1 -rp "Press any key..." </dev/tty
;;

4)
security_scan
read -n1 -rp "Press any key..." </dev/tty
;;

e|E)
break
;;

*)
echo -e "${RED}Invalid option${NC}"
sleep 1
;;

esac

done
