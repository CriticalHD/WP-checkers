#!/bin/bash
# ==================================
#      CHROMEBOOK WP DIAGNOSTIC
#      Version: 42
# ==================================

# ---------- COLORS ----------
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

clear
echo -e "\033[1;36mChromebook WP Diagnostic Script - Version 42 - By CriticalHD/neonnebula\033[0m"
echo -e "${YELLOW}==================================${NC}"
echo -e "${YELLOW}      CHROMEBOOK WP DIAGNOSTIC${NC}"
echo -e "${YELLOW}==================================${NC}"

# ---------- FUNCTIONS ----------
print_diagnostics() {

    echo -e "\n${GREEN}----- CROSSYSTEM (Firmware / DevMode info) -----${NC}"

    wpsw=$(crossystem wpsw_cur 2>/dev/null)
    devsw=$(crossystem devsw_cur 2>/dev/null)
    dev_usb=$(crossystem dev_boot_usb 2>/dev/null)
    dev_signed=$(crossystem dev_boot_signed_only 2>/dev/null)

    # ---------- GBB FLAGS CHECK ----------
    gbb_flags="unknown"
    gbb_modified=0

    if command -v flashrom >/dev/null 2>&1 && command -v futility >/dev/null 2>&1; then
        TMPGBB=$(mktemp)
        flashrom -p internal -i GBB -r "$TMPGBB" >/dev/null 2>&1
        gbb_flags=$(futility gbb --get --flags "$TMPGBB" 2>/dev/null | awk '{print $2}')
        rm -f "$TMPGBB"

        if [[ "$gbb_flags" != "0x0" && "$gbb_flags" != "0" && -n "$gbb_flags" ]]; then
            gbb_modified=1
        fi
    fi

    # ---------- CROSSYSTEM OUTPUT ----------
    echo -e "wpsw_cur: ${YELLOW}$wpsw${NC} â†’ $( [ "$wpsw" -eq 1 ] && echo -e "${RED}Flash write-protect ENABLED${NC}" || echo -e "${GREEN}Flash write-protect DISABLED${NC}" )"
    echo -e "devsw_cur: ${YELLOW}$devsw${NC} â†’ $( [ "$devsw" -eq 1 ] && echo -e "${GREEN}Developer Switch ON${NC}" || echo -e "${RED}Developer Switch OFF${NC}" )"

        gbb_dev_usb=0
    if [[ -n "$gbb_flags" ]]; then
        gbb_flags_dec=$((gbb_flags))
    if (( (gbb_flags_dec & 0x10) != 0 )); then
        gbb_dev_usb=1
    fi
fi

if [ "$dev_usb" -eq 1 ]; then
    echo -e "dev_boot_usb: ${YELLOW}$dev_usb${NC} â†’ ${GREEN}USB boot allowed${NC}"
else
    if [ "$gbb_dev_usb" -eq 1 ]; then
        echo -e "dev_boot_usb: ${YELLOW}$dev_usb${NC} â†’ ${GREEN}USB boot allowed (GBB SET: $gbb_flags)${NC}"
    else
        echo -e "dev_boot_usb: ${YELLOW}$dev_usb${NC} â†’ ${RED}USB boot disabled${NC}"
    fi
fi

    echo -e "dev_boot_signed_only: ${YELLOW}$dev_signed${NC} â†’ $( [ "$dev_signed" -eq 1 ] && echo -e "${RED}Boot signed-only enforced${NC}" || echo -e "${GREEN}Unsigned boot allowed${NC}" )"

    # ---------- GSC / Ti50 ----------
    echo -e "\n${GREEN}----- GSC / Ti50 Status -----${NC}"
    flash_wp=$(gsctool -a -w 2>/dev/null | grep -i "Flash WP" | awk '{print $3}')
    if [ -n "$flash_wp" ]; then
        color=$( [ "$flash_wp" == "enabled" ] && echo "${RED}" || echo "${GREEN}" )
        echo -e "Flash WP: ${color}${flash_wp^}${NC}"
    else
        echo -e "${RED}Flash WP status unavailable${NC}"
    fi

    # ---------- CCD INFO ----------
    echo -e "\n${GREEN}----- CCD Information -----${NC}"
    GSC_I=$(gsctool -a -I 2>/dev/null)
    GSC_W=$(gsctool -a -W 2>/dev/null)

    ccd_mode=$(echo "$GSC_W" | grep -i ccd_mode | tr -dc '0-9')
    echo -e "${YELLOW}CCD Mode is SPI Flash CCD Mode only${NC}"

    case "$ccd_mode" in
        0) echo -e "CCD Mode: ${RED}Locked / Closed${NC}" ;;
        1) echo -e "CCD Mode: ${GREEN}Opened${NC}" ;;
        2) echo -e "CCD Mode: ${BLUE}Debug${NC}" ;;
        *) echo -e "CCD Mode: ${YELLOW}Unknown${NC}" ;;
    esac

    ccd_state=$(echo "$GSC_I" | grep -i "^State" | awk '{print $2}')
    case "$ccd_state" in
        Locked) echo -e "CCD State: ${RED}Locked${NC}" ;;
        Opened|Open) echo -e "CCD State: ${GREEN}Opened${NC}" ;;
        Unlocked) echo -e "CCD State: ${GREEN}Unlocked${NC}" ;;
        Debug) echo -e "CCD State: ${BLUE}Debug${NC}" ;;
        *) echo -e "CCD State: ${YELLOW}Unknown${NC}" ;;
    esac

    get_cap() {
        cap="$1"
        line=$(echo "$GSC_I" | grep -i "$cap")
        line=$(echo "$line" | sed 's/^[YNyn] *//')
        state=$(echo "$line" | grep -oE 'Never|IfOpened|Always|0|1|2' | head -n1)
        case "$state" in
            Never|0) out="${RED}Never${NC}" ;;
            IfOpened|1) out="${BLUE}IfOpened${NC}" ;;
            Always|2) out="${GREEN}Always${NC}" ;;
            *) out="${YELLOW}Unknown${NC}" ;;
        esac
        printf "%-20s %b\n" "$cap:" "$out"
    }

    echo
    get_cap AllowUnverifiedRo
    get_cap OverrideWP
    get_cap FlashAP
    get_cap FlashRead
    get_cap GscFullConsole

    # ---------- SPI STATUS ----------
    echo -e "\n${GREEN}----- SPI Flash Status -----${NC}"
    if command -v flashrom >/dev/null 2>&1; then
        flash_status=$(flashrom --wp-status 2>/dev/null | grep -E "enabled|disabled")
        if [ -n "$flash_status" ]; then
            echo -e "${MAGENTA}$flash_status${NC}"
        else
            echo -e "${RED}SPI flash status unavailable${NC}"
        fi
    else
        echo -e "${RED}flashrom not installed${NC}"
    fi

    # ---------- KERNEL ----------
    echo -e "\n${GREEN}----- Kernel Messages -----${NC}"
    kernel_msgs=$(dmesg | grep -iE "write-protect|wp:|WP:|HWP" | tail -n 10)
    if [ -n "$kernel_msgs" ]; then
        echo -e "${CYAN}$kernel_msgs${NC}"
    else
        echo -e "${RED}No relevant WP or HWP kernel messages${NC}"
    fi

    # ---------- SPI READ TEST ----------
    echo -e "\n${GREEN}----- Firmware Read Test (SPI Only) -----${NC}"
    TMPFILE=$(mktemp)
    flashrom -p internal -r "$TMPFILE" >/dev/null 2>&1 &
    FR_PID=$!
    spinner="/-\|"
    i=0
    tput civis
    while kill -0 $FR_PID 2>/dev/null; do
        i=$(( (i+1) % 4 ))
        printf "\r\033[1;33mReading SPI flash... %s\033[0m" "${spinner:$i:1}"
        sleep 0.2
    done
    wait $FR_PID
    FR_STATUS=$?
    tput cnorm
    echo -ne "\r\033[K"
    if [ $FR_STATUS -eq 0 ]; then
        echo -e "${GREEN}Flash read SUCCESS (SPI access works)${NC}"
    else
        echo -e "${RED}Flash read FAILED${NC}"
    fi
    rm -f "$TMPFILE"
}

# ---------- INITIAL DIAGNOSTICS ----------
print_diagnostics

# ---------- PAYLOAD MENU ----------
[[ "$ccd_state" == "Locked" ]] && CCD_WARN="${RED}[CCD LOCKED]${NC}" || CCD_WARN=""
# Dynamically find the chronos user folder
USERDIR=$(ls -d /home/chronos/u-* | head -n1)
DOWNLOADS="$USERDIR/MyFiles/Downloads"
mkdir -p "$DOWNLOADS"

echo
echo -e "${CYAN}===== PAYLOAD MENU =====${NC}"
tput sc

while true; do
    tput rc
    tput ed
    echo
    echo -e "${GREEN}[1]${NC} Generate VT2 Diagnostic Log (saved to Downloads)"
    echo -e "${GREEN}[2]${NC} Set Important CCD Capabilities to Always ${CCD_WARN}"
    echo -e "${YELLOW}[e]${NC} Exit to VT2"
    echo

    read -n1 -rp "Choice: " choice </dev/tty
    echo

    case "$choice" in
1)
    TIMESTAMP=$(date +%Y%m%d_%H%M%S)
    LOCALFILE="$DOWNLOADS/vt2_log_$TIMESTAMP.log"

    echo -e "${CYAN}Generating VT2 Diagnostic Log...${NC}"

    {
        echo "===== VT2 DIAGNOSTIC LOG ====="
        date
        echo

# ---------- DEVICE INFORMATION ----------
        echo "===== DEVICE INFORMATION ====="

        HWID=$(crossystem hwid 2>/dev/null)
        HWID=${HWID:-unknown}

        MODEL=$(echo "$HWID" | awk '{print $1}' | cut -d'-' -f1)
        MODEL=${MODEL:-unknown}
        
        SERIAL=$(vpd -l 2>/dev/null | grep -i '^"serial_number"' | cut -d'=' -f2 | tr -d '"')
        SERIAL=${SERIAL:-unknown}
        
        FULL_VER=$(grep -oE 'CHROMEOS_RELEASE_VERSION=[^ ]+' /etc/lsb-release 2>/dev/null | cut -d'=' -f2)
        FULL_VER=${FULL_VER:-unknown}
        
        CHROME_VER=$(echo "$FULL_VER" | cut -d'.' -f1)
        CHROME_VER=${CHROME_VER:-unknown}
        
        TPM_VER=$(crossystem tpm_kernver 2>/dev/null)
        TPM_VER=${TPM_VER:-unknown}

    echo -e "HWID:        $HWID"
    echo -e "Model:       $MODEL ("use this on cros.tech to find board")"
    echo -e "Serial:      $SERIAL"
    echo -e "ChromeOS:    $CHROME_VER (Full: $FULL_VER)"
    echo -e "TPM Ver:     $TPM_VER"
echo

        echo "---- CROSSYSTEM ----"
        crossystem
        echo

        echo "---- GBB FLAGS ----"
        if command -v flashrom >/dev/null 2>&1 && command -v futility >/dev/null 2>&1; then
            TMPGBB=$(mktemp)
            flashrom -p internal -i GBB -r "$TMPGBB" >/dev/null 2>&1
            futility gbb --get --flags "$TMPGBB" 2>/dev/null
            rm -f "$TMPGBB"
        else
            echo "flashrom or futility missing"
        fi
        echo

        echo "---- GSC / CCD ----"
        gsctool -a -I 2>/dev/null
        echo

        echo "---- SPI FLASH STATUS ----"
        if command -v flashrom >/dev/null 2>&1; then
            flashrom --wp-status 2>/dev/null
        else
            echo "flashrom not installed"
        fi
        echo

        echo "---- KERNEL (WP / Firmware Messages) ----"
        dmesg | grep -iE "write-protect|wp:|WP:|flash|spi|HWP|ccd|gsc" | tail -n 50
        echo

    } > "$LOCALFILE"

    if [ -f "$LOCALFILE" ]; then
        echo -e "${GREEN}Log saved successfully!${NC}"
        echo -e "${YELLOW}Path:${NC} ${MAGENTA}$LOCALFILE${NC}"
    else
        echo -e "${RED}Failed to save log!${NC}"
    fi

    read -n1 -rp "Press any key to return to menu..." </dev/tty
;;
        2)
            echo -e "${CYAN}Setting CCD capabilities to Always...${NC}"
            gsctool -a -I FlashAP:always
            gsctool -a -I OverrideWP:always
            gsctool -a -I GscFullConsole:always
            gsctool -a -I OpenNoLongPP:always
            gsctool -a -I OpenNoDevMode:always
            gsctool -a -I AllowUnverifiedRo:always
            echo -e "${GREEN}CCD capabilities updated successfully!${NC}"
            read -n1 -rp "Press any key to return to menu..." </dev/tty
        ;;
        e|E)
            echo -e "${YELLOW}Exiting payload menu...${NC}"
            break
        ;;
        *)
            echo -e "${RED}Invalid option, please try again.${NC}"
            sleep 1
        ;;
    esac
done
