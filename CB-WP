#!/bin/bash

# ==================================
#      CHROMEBOOK WP DIAGNOSTIC
# ==================================

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}==================================${NC}"
echo -e "${YELLOW}      CHROMEBOOK WP DIAGNOSTIC${NC}"
echo -e "${YELLOW}==================================${NC}"

echo
echo -e "${GREEN}----- CROSSYSTEM (Firmware view) -----${NC}"
crossystem wpsw_cur 2>/dev/null

echo
echo -e "${GREEN}----- GSC / Ti50 Status -----${NC}"
gsctool -a -w 2>/dev/null | grep -E "Flash WP"

echo
echo -e "${GREEN}----- CCD Capabilities -----${NC}"
gsctool -a -I 2>/dev/null | grep -E "FlashAP|FlashEC|OverrideWP|Open"

echo
echo -e "${GREEN}----- SPI Flash Chip (Important Messages Only) -----${NC}"
flashrom --wp-status 2>/dev/null | grep -E "enabled|disabled" || echo -e "${RED}SPI flash status unavailable${NC}"

echo
echo -e "${GREEN}----- Kernel WP Messages (Important Only) -----${NC}"
dmesg | grep -i wp | grep -E "write-protect|wp" | tail -n 3 || echo -e "${RED}No relevant WP kernel messages${NC}"

echo
echo -e "${GREEN}----- Firmware Read Test (SPI Only) -----${NC}"
if flashrom -p host -r /tmp/wp_test_backup.bin 2>/dev/null | grep -q "Written"; then
    echo -e "${RED}Firmware read may have failed (unexpected output)${NC}"
else
    echo -e "${GREEN}Flash read SUCCESS (SPI access works)${NC}"
    rm -f /tmp/wp_test_backup.bin
fi

echo
echo -e "${YELLOW}==================================${NC}"
echo -e "${YELLOW}           DONE${NC}"
echo -e "${YELLOW}==================================${NC}"
