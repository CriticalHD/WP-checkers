#!/bin/bash
# ==================================
#      CHROMEBOOK WP DIAGNOSTIC
#      Version: 10
# ==================================

# Make version number visible at the top
echo -e "\033[1;36mChromebook WP Diagnostic Script - Version 10\033[0m"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}==================================${NC}"
echo -e "${YELLOW}      CHROMEBOOK WP DIAGNOSTIC${NC}"
echo -e "${YELLOW}==================================${NC}"

# ---- CROSSYSTEM (Decoded Firmware view) ----
echo
echo -e "${GREEN}----- CROSSYSTEM (Firmware / DevMode info) -----${NC}"
wpsw=$(crossystem wpsw_cur 2>/dev/null)
devsw=$(crossystem devsw_cur 2>/dev/null)
dev_usb=$(crossystem dev_boot_usb 2>/dev/null)
dev_signed=$(crossystem dev_boot_signed_only 2>/dev/null)

echo -e "wpsw_cur: $wpsw â†’ $( [ "$wpsw" -eq 1 ] && echo 'Flash write-protect ENABLED' || echo 'Flash write-protect DISABLED' )"
echo -e "devsw_cur: $devsw â†’ $( [ "$devsw" -eq 1 ] && echo 'Developer Switch ON' || echo 'Developer Switch OFF' )"
echo -e "dev_boot_usb: $dev_usb â†’ $( [ "$dev_usb" -eq 1 ] && echo 'USB boot allowed' || echo 'USB boot disabled' )"
echo -e "dev_boot_signed_only: $dev_signed â†’ $( [ "$dev_signed" -eq 1 ] && echo 'Boot signed-only enforced' || echo 'Unsigned boot allowed' )"

# ---- GSC / Ti50 Status (Compact) ----
echo
echo -e "${GREEN}----- GSC / Ti50 Status (Compact) -----${NC}"
gsctool -a -w 2>/dev/null | awk '{$1=$1; print}' | paste -sd ", " -

# ---- CCD Capabilities (Fixed & Color Coded) ----
echo
echo -e "${GREEN}----- CCD Capabilities -----${NC}"
gsctool -a -I 2>/dev/null | grep -v "UartGSC" | while read -r line; do
    name=$(echo "$line" | awk '{print $1}')
    value=$(echo "$line" | awk '{print $2}')

    # Map numeric or letter values to human-readable color-coded states
    case "$value" in
        0) state="${RED}Never${NC}";;
        1) state="${BLUE}If Opened${NC}";;
        2) state="${GREEN}Always${NC}";;
        "") state="${RED}Locked / Not readable${NC}";;
        Y|y) state="${GREEN}Yes${NC}";;
        N|n) state="${RED}No${NC}";;
        *) state="$value";;
    esac

    echo -e "$name: $state"
done

# ---- SPI Flash Chip ----
echo
echo -e "${GREEN}----- SPI Flash Chip (Important Only) -----${NC}"
flashrom --wp-status 2>/dev/null | grep -E "enabled|disabled" || echo -e "${RED}SPI flash status unavailable${NC}"

# ---- Kernel WP / HWP Messages ----
echo
echo -e "${GREEN}----- Kernel WP / HWP Messages (Important Only) -----${NC}"
dmesg | grep -iE "write-protect|wp:|WP:|HWP" | tail -n 5 || echo -e "${RED}No relevant WP or HWP kernel messages${NC}"

# ---- Firmware Read Test ----
echo
echo -e "${GREEN}----- Firmware Read Test (SPI Only) -----${NC}"
TMPFILE=$(mktemp)
if flashrom -p host -r "$TMPFILE" >/dev/null 2>&1; then
    echo -e "${GREEN}Flash read SUCCESS (SPI access works)${NC}"
    rm -f "$TMPFILE"
else
    echo -e "${RED}Flash read FAILED${NC}"
fi

echo
echo -e "${YELLOW}==================================${NC}"
echo -e "${YELLOW}           DONE${NC}"
echo -e "${YELLOW}==================================${NC}"
