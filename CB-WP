#!/bin/bash
# ==================================
#      CHROMEBOOK WP DIAGNOSTIC
#      Version: 12
# ==================================

# Make version number visible at the top
echo -e "\033[1;36mChromebook WP Diagnostic Script - Version 12\033[0m"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}==================================${NC}"
echo -e "${YELLOW}      CHROMEBOOK WP DIAGNOSTIC${NC}"
echo -e "${YELLOW}==================================${NC}"

# ---- CROSSYSTEM (Decoded Firmware view) ----
echo
echo -e "${GREEN}----- CROSSYSTEM (Firmware / DevMode info) -----${NC}"
wpsw=$(crossystem wpsw_cur 2>/dev/null)
devsw=$(crossystem devsw_cur 2>/dev/null)
dev_usb=$(crossystem dev_boot_usb 2>/dev/null)
dev_signed=$(crossystem dev_boot_signed_only 2>/dev/null)

echo -e "wpsw_cur: ${YELLOW}$wpsw${NC} → $( [ "$wpsw" -eq 1 ] && echo -e "${RED}Flash write-protect ENABLED${NC}" || echo -e "${GREEN}Flash write-protect DISABLED${NC}" )"
echo -e "devsw_cur: ${YELLOW}$devsw${NC} → $( [ "$devsw" -eq 1 ] && echo -e "${GREEN}Developer Switch ON${NC}" || echo -e "${RED}Developer Switch OFF${NC}" )"
echo -e "dev_boot_usb: ${YELLOW}$dev_usb${NC} → $( [ "$dev_usb" -eq 1 ] && echo -e "${GREEN}USB boot allowed${NC}" || echo -e "${RED}USB boot disabled${NC}" )"
echo -e "dev_boot_signed_only: ${YELLOW}$dev_signed${NC} → $( [ "$dev_signed" -eq 1 ] && echo -e "${RED}Boot signed-only enforced${NC}" || echo -e "${GREEN}Unsigned boot allowed${NC}" )"

# ---- GSC / Ti50 Status (Compact) ----
echo
echo -e "${GREEN}----- GSC / Ti50 Status (Compact) -----${NC}"
gsctool -a -w 2>/dev/null | awk '{$1=$1; print}' | paste -sd ", " -

# ---- CCD Capabilities (Fixed & Color Coded) ----
echo
echo -e "${GREEN}----- CCD Capabilities -----${NC}"
gsctool -a -I 2>/dev/null | grep -v "UartGSC" | while read -r line; do
    name=$(echo "$line" | awk '{print $1}')
    value=$(echo "$line" | awk '{print $2}')

    # Map numeric or letter values to human-readable color-coded states
    case "$value" in
        0) state="${RED}Never${NC}";;
        1) state="${BLUE}If Opened${NC}";;
        2) state="${GREEN}Always${NC}";;
        "") state="${RED}Locked / Not readable${NC}";;
        Y|y) state="${GREEN}Yes${NC}";;
        N|n) state="${RED}No${NC}";;
        *) state="$value";;
    esac

    echo -e "$name: $state"
done

# ---- SPI Flash Chip ----
echo -e "\n${GREEN}----- SPI Flash Chip (Important Only) -----${NC}"
if command -v flashrom >/dev/null 2>&1; then
    flash_status=$(flashrom --wp-status 2>/dev/null | grep -E "enabled|disabled")
    if [ -n "$flash_status" ]; then
        echo -e "${MAGENTA}$flash_status${NC}"
    else
        echo -e "${RED}SPI flash status unavailable${NC}"
    fi
else
    echo -e "${RED}flashrom not installed${NC}"
fi

# ---- Kernel WP / HWP Messages ----
echo
echo -e "\n${GREEN}----- Kernel WP / HWP Messages (Important Only) -----${NC}"
kernel_msgs=$(dmesg | grep -iE "write-protect|wp:|WP:|HWP" | tail -n 5)
if [ -n "$kernel_msgs" ]; then
    echo -e "${CYAN}$kernel_msgs${NC}"
else
    echo -e "${RED}No relevant WP or HWP kernel messages${NC}"
fi


# ---- Firmware Read Test ----
echo
echo -e "${GREEN}----- Firmware Read Test (SPI Only) -----${NC}"
TMPFILE=$(mktemp)
if flashrom -p host -r "$TMPFILE" >/dev/null 2>&1; then
    echo -e "${GREEN}Flash read SUCCESS (SPI access works)${NC}"
    rm -f "$TMPFILE"
else
    echo -e "${RED}Flash read FAILED${NC}"
fi

echo
echo -e "${YELLOW}==================================${NC}"
echo -e "${YELLOW}           DONE${NC}"
echo -e "${YELLOW}==================================${NC}"
