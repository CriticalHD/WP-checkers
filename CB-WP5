#!/bin/bash
# ==================================
#      CHROMEBOOK WP DIAGNOSTIC
#      Version: 11
# ==================================

# ---- COLORS ----
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}==================================${NC}"
echo -e "${CYAN} Chromebook WP Diagnostic v11${NC}"
echo -e "${CYAN}==================================${NC}"

# ------------------------------
# CCD MODE CHECK
# ------------------------------

echo
echo -e "${GREEN}----- CCD Status -----${NC}"

ccd_mode=$(gsctool -a -W 2>/dev/null | grep -i ccd_mode | awk '{print $2}')

case "$ccd_mode" in
    0)
        echo -e "CCD Mode: ${RED}Locked / Closed${NC}"
        ;;
    1)
        echo -e "CCD Mode: ${GREEN}Opened${NC}"
        ;;
    2)
        echo -e "CCD Mode: ${BLUE}Debug${NC}"
        ;;
    *)
        echo -e "CCD Mode: ${YELLOW}Unknown${NC}"
        ;;
esac

# ------------------------------
# CCD CAPABILITIES (ONLY IMPORTANT)
# ------------------------------

echo
echo -e "${GREEN}----- CCD Important Capabilities -----${NC}"

check_cap () {

cap=$(gsctool -a -I 2>/dev/null | grep "$1" | awk '{print $NF}')

case "$cap" in
    0)
        state="${RED}Never${NC}"
        ;;
    1)
        state="${BLUE}If Opened${NC}"
        ;;
    2)
        state="${GREEN}Always${NC}"
        ;;
    Y|y)
        state="${GREEN}Enabled${NC}"
        ;;
    N|n)
        state="${RED}Disabled${NC}"
        ;;
    *)
        state="${YELLOW}Unknown${NC}"
        ;;
esac

printf "%-20s %b\n" "$1:" "$state"

}

check_cap "AllowUnverifiedRo"
check_cap "OverrideWP"
check_cap "FlashAP"
check_cap "FlashRead"
check_cap "GscFullConsole"

# ------------------------------
# GSC FLASH WRITE PROTECT
# ------------------------------

echo
echo -e "${GREEN}----- GSC Flash Write Protect -----${NC}"

flash_wp=$(gsctool -a -w 2>/dev/null | grep "Flash WP" | awk '{print $3}')

if [[ "$flash_wp" == "enabled" ]]; then
    echo -e "Flash WP: ${RED}Enabled${NC}"
elif [[ "$flash_wp" == "disabled" ]]; then
    echo -e "Flash WP: ${GREEN}Disabled${NC}"
else
    echo -e "Flash WP: ${YELLOW}Unknown${NC}"
fi

echo
echo -e "${CYAN}==================================${NC}"
echo -e "${CYAN}           DONE${NC}"
echo -e "${CYAN}==================================${NC}"
