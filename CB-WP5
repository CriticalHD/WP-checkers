#!/bin/bash
# ==================================
# Chromebook WP Diagnostic
# Version 11.6
# ==================================

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${CYAN}================================${NC}"
echo -e "${CYAN} Chromebook WP Diagnostic 11.6${NC}"
echo -e "${CYAN}================================${NC}"

echo
echo -e "${GREEN}----- CCD Information -----${NC}"

GSC_I=$(gsctool -a -I 2>/dev/null)
GSC_W=$(gsctool -a -W 2>/dev/null)

# CCD Mode
ccd_mode=$(echo "$GSC_W" | grep -i ccd_mode | tr -dc '0-9')
echo -e "${YELLOW}CCD Mode is not the actual CCD Open/Closed, it is only the SPI Flash CCD Mode${NC}"

case "$ccd_mode" in
0) echo -e "CCD Mode: ${RED}Locked / Closed${NC}" ;;
1) echo -e "CCD Mode: ${GREEN}Opened${NC}" ;;
2) echo -e "CCD Mode: ${BLUE}Debug${NC}" ;;
*) echo -e "CCD Mode: ${YELLOW}Unknown${NC}" ;;
esac

echo

# Function to check capability
get_cap() {

cap="$1"

line=$(echo "$GSC_I" | grep -i "$cap")

# remove leading flags
line=$(echo "$line" | sed 's/^[YNyn] *//')

state=$(echo "$line" | grep -oE 'Never|IfOpened|Always|0|1|2' | head -n1)

case "$state" in
Never|0) out="${RED}Never${NC}" ;;
IfOpened|1) out="${BLUE}IfOpened${NC}" ;;
Always|2) out="${GREEN}Always${NC}" ;;
*) out="${YELLOW}Unknown${NC}" ;;
esac

printf "%-20s %b\n" "$cap:" "$out"

}

get_cap AllowUnverifiedRo
get_cap OverrideWP
get_cap FlashAP
get_cap FlashRead
get_cap GscFullConsole


echo
echo -e "${GREEN}----- Flash Write Protect -----${NC}"

wp=$(gsctool -a -w 2>/dev/null)

if echo "$wp" | grep -qi enabled; then
echo -e "Flash WP: ${RED}Enabled${NC}"
elif echo "$wp" | grep -qi disabled; then
echo -e "Flash WP: ${GREEN}Disabled${NC}"
else
echo -e "Flash WP: ${YELLOW}Unknown${NC}"
fi

echo
echo -e "${CYAN}================================${NC}"
echo -e "${CYAN} DONE${NC}"
echo -e "${CYAN}================================${NC}"
