#!/bin/bash
# =====================================================
#      ChromeOS Forensic Suite
#        Core + Extended Modules
#           Version 1.0 (Merged)
# =====================================================
# Safe, read-only, color-coded, summarized outputs
# Single consolidated report, interactive menu included

# ---------- COLORS ----------
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

# ---------- REPORT ----------
REPORT="/tmp/chromeos_forensic_$(date +%s).log"
flags=0  # global GBB flags

log(){
    echo "$1" | tee -a "$REPORT"
}

section(){
    echo -e "\n${GREEN}===== $1 =====${NC}"
    log "===== $1 ====="
}

# =========================
# SYSTEM INFO
# =========================
system_info(){
    section "SYSTEM INFORMATION"
    board=$(crossystem hwid 2>/dev/null)
    fwid=$(crossystem fwid 2>/dev/null)
    kernel=$(uname -r)
    arch=$(uname -m)
    os=$(uname -o 2>/dev/null || echo "Unknown")

    echo -e "Hardware ID: ${YELLOW}$board${NC}"
    echo -e "Firmware ID: ${YELLOW}$fwid${NC}"
    echo -e "Kernel Version: ${YELLOW}$kernel${NC}"
    echo -e "Architecture: ${YELLOW}$arch${NC}"
    echo -e "OS Type: ${YELLOW}$os${NC}"

    log "HWID=$board FWID=$fwid KERNEL=$kernel ARCH=$arch OS=$os"
}

# =========================
# CROSSYSTEM FLAGS
# =========================
crossystem_analysis(){
    section "CROSSYSTEM FLAGS"

    wpsw=$(crossystem wpsw_cur 2>/dev/null)
    devsw=$(crossystem devsw_cur 2>/dev/null)
    usbboot=$(crossystem dev_boot_usb 2>/dev/null)
    signed=$(crossystem dev_boot_signed_only 2>/dev/null)

    echo -ne "Write Protect Switch: "
    [ "$wpsw" -eq 1 ] && echo -e "${RED}ENABLED${NC}" || echo -e "${GREEN}DISABLED${NC}"
    echo -ne "Developer Mode: "
    [ "$devsw" -eq 1 ] && echo -e "${GREEN}ON${NC}" || echo -e "${RED}OFF${NC}"
    echo -ne "USB Boot: "
    [ "$usbboot" -eq 1 ] && echo -e "${GREEN}ALLOWED${NC}" || echo -e "${RED}BLOCKED${NC}"
    echo -ne "Signed Boot Enforcement: "
    [ "$signed" -eq 1 ] && echo -e "${RED}ENFORCED${NC}" || echo -e "${GREEN}DISABLED${NC}"

    log "WP=$wpsw DEV_MODE=$devsw USB_BOOT=$usbboot SIGNED=$signed"
}

# =========================
# CCD SECURITY
# =========================
ccd_analysis(){
    section "CCD / Ti50 SECURITY"
    GSC=$(gsctool -a -I 2>/dev/null)
    ccd_state=$(echo "$GSC" | grep -i "^State" | awk '{print $2}')
    ccd_mode=$(gsctool -a -W 2>/dev/null | grep -i ccd_mode | tr -dc '0-9')

    echo -ne "CCD State: "
    case "$ccd_state" in
        Locked) echo -e "${GREEN}Locked${NC}" ;;
        Opened|Open) echo -e "${YELLOW}Opened${NC}" ;;
        Unlocked) echo -e "${YELLOW}Unlocked${NC}" ;;
        Debug) echo -e "${BLUE}Debug${NC}" ;;
        *) echo -e "${RED}Unknown${NC}" ;;
    esac
    log "CCD_STATE=$ccd_state"

    echo -ne "CCD Mode: "
    case "$ccd_mode" in
        0) echo -e "${RED}Locked${NC}" ;;
        1) echo -e "${GREEN}Opened${NC}" ;;
        2) echo -e "${BLUE}Debug${NC}" ;;
        *) echo -e "${YELLOW}Unknown${NC}" ;;
    esac
    log "CCD_MODE=$ccd_mode"

    echo "CCD Capabilities Summary:"
    echo "$GSC" | grep -E "Flash|Console|Override|Ro" | head -n 10 | tee -a "$REPORT"
    echo "...(truncated)" | tee -a "$REPORT"
}

# =========================
# SPI FLASH SUMMARY
# =========================
spi_summary(){
    section "SPI FLASH SUMMARY"
    if ! command -v flashrom >/dev/null 2>&1; then
        echo -e "${RED}flashrom not installed${NC}"
        return
    fi
    echo "Write-Protect Status:"
    flashrom -p internal --wp-status 2>/dev/null | tee -a "$REPORT"
    echo "Flash Regions (summary):"
    flashrom -p internal 2>/dev/null | grep region | head -n 20 | tee -a "$REPORT"
    echo "...(truncated)" | tee -a "$REPORT"
}

# =========================
# KERNEL SECURITY LOGS
# =========================
kernel_logs(){
    section "KERNEL SECURITY LOGS (Last 20 relevant lines)"
    dmesg | grep -iE "write-protect|wp:|HWP|tpm|gsc" | tail -n 20 | tee -a "$REPORT"
    total_matches=$(dmesg | grep -iE "write-protect|wp:|HWP|tpm|gsc" | wc -l)
    echo "...Total matches: $total_matches" | tee -a "$REPORT"
}

# =========================
# GBB DEEP DECODING
# =========================
gbb_deep(){
    section "GBB DEEP DECODE"
    local TMPGBB=$(mktemp)
    flags=0
    if command -v flashrom >/dev/null 2>&1 && command -v futility >/dev/null 2>&1; then
        flashrom -p internal -i GBB -r "$TMPGBB" >/dev/null 2>&1
        flags=$(futility gbb --get --flags "$TMPGBB" 2>/dev/null | awk '{print $2}')
    else
        echo -e "${RED}flashrom or futility not installed, cannot read GBB${NC}"
    fi
    rm -f "$TMPGBB"

    echo "Raw GBB Flags: $flags"
    log "GBB_FLAGS=$flags"

    decode_flag(){
        local mask=$1
        local name=$2
        val=$((flags & mask))
        if [ "$val" -gt 0 ]; then
            echo -e "${YELLOW}$name ENABLED${NC}"
            log "$name=1"
        else
            echo "$name disabled"
            log "$name=0"
        fi
    }

    decode_flag 8 "Force Dev Mode"
    decode_flag 16 "Force USB Boot"
    decode_flag 32 "Disable FW Verification"
    decode_flag 64 "Disable EC Software Sync"
    decode_flag 128 "Recovery Disabled"
    decode_flag 256 "Recovery Forced"
    decode_flag 512 "Custom Flag"
}

# =========================
# INTEL ME FORENSICS
# =========================
me_forensics(){
    section "INTEL MANAGEMENT ENGINE (ME) ANALYSIS"
    if ! command -v flashrom >/dev/null 2>&1; then
        echo -e "${RED}flashrom not installed${NC}"
        return
    fi
    regions=$(flashrom -p internal 2>/dev/null)
    if echo "$regions" | grep -qi "ME"; then
        echo -e "${MAGENTA}Intel ME region detected${NC}"
        echo "ME protections typically include:" | tee -a "$REPORT"
        echo "- Blocks BIOS writes" | tee -a "$REPORT"
        echo "- Enforces descriptor permissions" | tee -a "$REPORT"
        echo "- Blocks direct SPI access" | tee -a "$REPORT"
        echo "- Protects boot firmware" | tee -a "$REPORT"
    else
        echo -e "${GREEN}No Intel ME region detected${NC}"
    fi
}

# =========================
# EXPLOIT / TAMPERING DETECTION
# =========================
exploit_detection(){
    section "FIRMWARE MODIFICATION / TAMPERING DETECTION"
    if [[ "$flags" != "0x0" ]]; then
        echo -e "${YELLOW}GBB flags non-default: possible firmware modification${NC}"
    fi
    local ccd_state=$(gsctool -a -I 2>/dev/null | grep -i "^State" | awk '{print $2}')
    if [[ "$ccd_state" != "Locked" ]]; then
        echo -e "${YELLOW}CCD not fully locked: debug/dev features enabled${NC}"
    fi
    if crossystem dev_boot_usb 2>/dev/null | grep -q 1; then
        echo "USB boot allowed"
    fi
    if crossystem devsw_cur 2>/dev/null | grep -q 1; then
        echo "Developer mode enabled"
    fi
}

# =========================
# SPI READ TEST
# =========================
spi_read_test(){
    section "SPI READ TEST"
    local TMP=$(mktemp)
    flashrom -p internal -r "$TMP" >/dev/null 2>&1
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}SPI read successful${NC}"
    else
        echo -e "${RED}SPI read failed${NC}"
    fi
    rm -f "$TMP"
}

# =========================
# INTERACTIVE MODULE MENU
# =========================
interactive_menu(){
    section "EXTENDED FORENSIC MENU"
    echo -e "${CYAN}[1] GBB Deep Decode${NC}"
    echo -e "${CYAN}[2] Intel ME Analysis${NC}"
    echo -e "${CYAN}[3] Exploit / Tamper Detection${NC}"
    echo -e "${CYAN}[4] SPI Read Test${NC}"
    echo -e "${CYAN}[E] Exit${NC}"

    while true; do
        read -n1 -rp "Choice: " choice </dev/tty
        echo
        case "$choice" in
            1) gbb_deep; read -n1 -rp "Press any key to return..." </dev/tty ;;
            2) me_forensics; read -n1 -rp "Press any key to return..." </dev/tty ;;
            3) exploit_detection; read -n1 -rp "Press any key to return..." </dev/tty ;;
            4) spi_read_test; read -n1 -rp "Press any key to return..." </dev/tty ;;
            e|E) break ;;
            *) echo -e "${RED}Invalid option${NC}" ;;
        esac
        echo
    done
}

# =========================
# RUN ALL CORE + EXTENDED MODULES
# =========================
system_info
crossystem_analysis
ccd_analysis
spi_summary
kernel_logs
gbb_deep
me_forensics
exploit_detection
spi_read_test
interactive_menu

section "FINAL FORENSIC REPORT SUMMARY"
echo "Report saved to: $REPORT"
echo -e "${CYAN}ChromeOS forensic suite complete.${NC}"
