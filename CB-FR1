#!/bin/bash
# =====================================================
#        CHROMEOS FIRMWARE FORENSIC SUITE
#              Version 2.0
#         Deep Firmware Inspection
# =====================================================

# ---------- COLORS ----------
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'

clear

echo -e "${CYAN}"
echo "=================================================="
echo "        ChromeOS Firmware Forensic Suite"
echo "                 Version 2.0"
echo "=================================================="
echo -e "${NC}"

REPORT="/tmp/chromeos_firmware_report_$(date +%s).log"

log(){
echo "$1" >> "$REPORT"
}

section(){
echo
echo -e "${GREEN}----- $1 -----${NC}"
log "----- $1 -----"
}

# =====================================================
# SYSTEM INFO
# =====================================================

system_info(){

section "SYSTEM INFORMATION"

board=$(crossystem hwid 2>/dev/null)
fwid=$(crossystem fwid 2>/dev/null)

echo -e "Hardware ID: ${YELLOW}$board${NC}"
echo -e "Firmware ID: ${YELLOW}$fwid${NC}"

log "HWID: $board"
log "FWID: $fwid"

}

# =====================================================
# CROSSYSTEM ANALYSIS
# =====================================================

crossystem_analysis(){

section "CROSSYSTEM SECURITY FLAGS"

wpsw=$(crossystem wpsw_cur 2>/dev/null)
devsw=$(crossystem devsw_cur 2>/dev/null)
usbboot=$(crossystem dev_boot_usb 2>/dev/null)
signed=$(crossystem dev_boot_signed_only 2>/dev/null)

printf "Write Protect Switch: "
[ "$wpsw" -eq 1 ] && echo -e "${RED}ENABLED${NC}" || echo -e "${GREEN}DISABLED${NC}"

printf "Developer Mode: "
[ "$devsw" -eq 1 ] && echo -e "${GREEN}ON${NC}" || echo -e "${RED}OFF${NC}"

printf "USB Boot: "
[ "$usbboot" -eq 1 ] && echo -e "${GREEN}ALLOWED${NC}" || echo -e "${RED}BLOCKED${NC}"

printf "Signed Firmware Enforcement: "
[ "$signed" -eq 1 ] && echo -e "${RED}ENFORCED${NC}" || echo -e "${GREEN}DISABLED${NC}"

}

# =====================================================
# FAST GBB ANALYSIS
# =====================================================

gbb_analysis(){

section "GBB FLAG ANALYSIS"

TMPGBB=$(mktemp)

flashrom -p internal -i GBB -r "$TMPGBB" >/dev/null 2>&1

flags=$(futility gbb --get --flags "$TMPGBB" 2>/dev/null | awk '{print $2}')

rm -f "$TMPGBB"

echo "Raw GBB Flags: $flags"
log "GBB_FLAGS=$flags"

if [[ "$flags" != "0x0" ]]; then
echo -e "${YELLOW}Firmware flags are modified.${NC}"
fi

# decode common flags

decode_flag(){

mask=$1
name=$2

val=$((flags & mask))

if [ "$val" -gt 0 ]; then
echo -e "${YELLOW}$name ENABLED${NC}"
log "$name=1"
else
echo "$name disabled"
log "$name=0"
fi

}

decode_flag 8 "Force Dev Mode"
decode_flag 16 "Force USB Boot"
decode_flag 32 "Disable FW Verification"
decode_flag 64 "Disable EC Software Sync"

}

# =====================================================
# CCD SECURITY ANALYSIS
# =====================================================

ccd_analysis(){

section "CCD SECURITY"

GSC=$(gsctool -a -I 2>/dev/null)

state=$(echo "$GSC" | grep -i "^State" | awk '{print $2}')

echo "CCD State: $state"

if [[ "$state" == "Locked" ]]; then
echo -e "${GREEN}CCD fully locked.${NC}"
else
echo -e "${YELLOW}CCD unlocked or debug capable.${NC}"
fi

echo
echo "Capabilities:"
echo "$GSC" | grep -E "Flash|Console|Override|Ro"

}

# =====================================================
# SPI FLASH ANALYSIS
# =====================================================

spi_analysis(){

section "SPI FLASH LAYOUT"

flashrom -p internal --wp-status 2>/dev/null

echo
echo "Flash Regions:"

flashrom -p internal 2>/dev/null | grep region

}

# =====================================================
# MANAGEMENT ENGINE FORENSICS
# =====================================================

me_analysis(){

section "INTEL MANAGEMENT ENGINE ANALYSIS"

regions=$(flashrom -p internal 2>/dev/null)

if echo "$regions" | grep -qi "ME"; then

echo -e "${MAGENTA}Intel ME region detected${NC}"

echo
echo "ME protections typically include:"
echo "- blocking BIOS writes"
echo "- enforcing descriptor permissions"
echo "- blocking direct SPI access"
echo "- protecting boot firmware"

else

echo -e "${GREEN}No Intel ME region detected${NC}"

fi

}

# =====================================================
# KERNEL SECURITY EVENTS
# =====================================================

kernel_logs(){

section "KERNEL SECURITY EVENTS"

dmesg | grep -iE "write|wp|tpm|gsc" | tail -n 20

}

# =====================================================
# EXPLOIT DETECTION
# =====================================================

exploit_detection(){

section "FIRMWARE MODIFICATION DETECTION"

flags=$(crossystem dev_boot_usb 2>/dev/null)

if [[ "$flags" == "1" ]]; then
echo "USB boot allowed"
fi

if crossystem devsw_cur | grep -q 1; then
echo "Developer mode enabled"
fi

}

# =====================================================
# SPI READ TEST
# =====================================================

spi_test(){

section "SPI ACCESS TEST"

TMP=$(mktemp)

flashrom -p internal -r "$TMP" >/dev/null 2>&1

if [ $? -eq 0 ]; then
echo -e "${GREEN}SPI read successful${NC}"
else
echo -e "${RED}SPI read failed${NC}"
fi

rm -f "$TMP"

}

# =====================================================
# REPORT GENERATOR
# =====================================================

report_save(){

section "FORENSIC REPORT"

echo "Report saved to:"
echo "$REPORT"

}

# =====================================================
# RUN ALL ANALYSIS
# =====================================================

system_info
crossystem_analysis
gbb_analysis
ccd_analysis
spi_analysis
me_analysis
kernel_logs
exploit_detection
spi_test
report_save

echo
echo -e "${CYAN}Forensic analysis complete.${NC}"
