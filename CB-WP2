#!/bin/bash
# ==================================
#      CHROMEBOOK WP DIAGNOSTIC
#      Version: 10
# ==================================

# ---- COLOR CODES ----
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

# ---- HEADER ----
echo -e "${CYAN}==================================${NC}"
echo -e "${CYAN}  Chromebook WP Diagnostic v10  ${NC}"
echo -e "${CYAN}==================================${NC}"

# ---- CROSSYSTEM (Firmware / DevMode info) ----
echo -e "\n${GREEN}----- CROSSYSTEM (Firmware / DevMode info) -----${NC}"
wpsw=$(crossystem wpsw_cur 2>/dev/null)
devsw=$(crossystem devsw_cur 2>/dev/null)
dev_usb=$(crossystem dev_boot_usb 2>/dev/null)
dev_signed=$(crossystem dev_boot_signed_only 2>/dev/null)

echo -e "wpsw_cur: ${YELLOW}$wpsw${NC} → $( [ "$wpsw" -eq 1 ] && echo -e "${RED}Flash write-protect ENABLED${NC}" || echo -e "${GREEN}Flash write-protect DISABLED${NC}" )"
echo -e "devsw_cur: ${YELLOW}$devsw${NC} → $( [ "$devsw" -eq 1 ] && echo -e "${GREEN}Developer Switch ON${NC}" || echo -e "${RED}Developer Switch OFF${NC}" )"
echo -e "dev_boot_usb: ${YELLOW}$dev_usb${NC} → $( [ "$dev_usb" -eq 1 ] && echo -e "${GREEN}USB boot allowed${NC}" || echo -e "${RED}USB boot disabled${NC}" )"
echo -e "dev_boot_signed_only: ${YELLOW}$dev_signed${NC} → $( [ "$dev_signed" -eq 1 ] && echo -e "${RED}Boot signed-only enforced${NC}" || echo -e "${GREEN}Unsigned boot allowed${NC}" )"

# ---- GSC / Ti50 Status (Simplified) ----
echo -e "\n${GREEN}----- GSC / Ti50 Status -----${NC}"
flash_wp=$(gsctool -a -w 2>/dev/null | grep -i "Flash WP" | awk '{print $3}')
if [ -n "$flash_wp" ]; then
    color=$( [ "$flash_wp" == "enabled" ] && echo -e "${RED}" || echo -e "${GREEN}" )
    echo -e "Flash WP: ${color}${flash_wp^}${NC}"  # Capitalize first letter
else
    echo -e "${RED}Flash WP status unavailable${NC}"
fi

# ---- CCD Capabilities (Fixed, Color Coded, Two-Column) ----
echo -e "\n${GREEN}----- CCD Capabilities -----${NC}"

# Read CCD features into an array, skip headers and empty lines
mapfile -t ccd_lines < <(gsctool -a -I 2>/dev/null | grep -vE "UartGSC|CCD: caps|Capabilities: current" | grep -v "^$")

# Loop through array two at a time for two-column display
for ((i=0; i<${#ccd_lines[@]}; i+=2)); do
    line1=${ccd_lines[i]}
    line2=${ccd_lines[i+1]}

    # Parse first line
    name1=$(echo "$line1" | awk '{print $1}')
    value1=$(echo "$line1" | awk '{print $2}')
    case "$value1" in
        0) state1="${RED}Never${NC}";;
        1) state1="${BLUE}If Opened${NC}";;
        2) state1="${GREEN}Always${NC}";;
        Y|y) state1="${GREEN}Yes${NC}";;
        N|n) state1="${RED}No${NC}";;
        "") state1="${RED}Locked / Not readable${NC}";;
        *) state1="$value1";;
    esac

    # Parse second line (if exists)
    if [ -n "$line2" ]; then
        name2=$(echo "$line2" | awk '{print $1}')
        value2=$(echo "$line2" | awk '{print $2}')
        case "$value2" in
            0) state2="${RED}Never${NC}";;
            1) state2="${BLUE}If Opened${NC}";;
            2) state2="${GREEN}Always${NC}";;
            Y|y) state2="${GREEN}Yes${NC}";;
            N|n) state2="${RED}No${NC}";;
            "") state2="${RED}Locked / Not readable${NC}";;
            *) state2="$value2";;
        esac
        printf "%-20s %-15s | %-20s %-15s\n" "$name1:" "$state1" "$name2:" "$state2"
    else
        printf "%-20s %-15s\n" "$name1:" "$state1"
    fi
done

# ---- SPI Flash Chip ----
echo -e "\n${GREEN}----- SPI Flash Chip (Important Only) -----${NC}"
if command -v flashrom >/dev/null 2>&1; then
    flash_status=$(flashrom --wp-status 2>/dev/null | grep -E "enabled|disabled")
    if [ -n "$flash_status" ]; then
        echo -e "${MAGENTA}$flash_status${NC}"
    else
        echo -e "${RED}SPI flash status unavailable${NC}"
    fi
else
    echo -e "${RED}flashrom not installed${NC}"
fi

# ---- Kernel WP / HWP Messages ----
echo -e "\n${GREEN}----- Kernel WP / HWP Messages (Important Only) -----${NC}"
kernel_msgs=$(dmesg | grep -iE "write-protect|wp:|WP:|HWP" | tail -n 5)
if [ -n "$kernel_msgs" ]; then
    echo -e "${CYAN}$kernel_msgs${NC}"
else
    echo -e "${RED}No relevant WP or HWP kernel messages${NC}"
fi

# ---- Firmware Read Test ----
echo -e "\n${GREEN}----- Firmware Read Test (SPI Only) -----${NC}"
TMPFILE=$(mktemp)
if flashrom -p host -r "$TMPFILE" >/dev/null 2>&1; then
    echo -e "${GREEN}Flash read SUCCESS (SPI access works)${NC}"
    rm -f "$TMPFILE"
else
    echo -e "${RED}Flash read FAILED${NC}"
fi

# ---- FOOTER ----
echo -e "\n${YELLOW}==================================${NC}"
echo -e "${YELLOW}           DONE${NC}"
echo -e "${YELLOW}==================================${NC}"
